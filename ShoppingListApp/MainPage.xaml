<?xml version="1.0" encoding="utf-8" ?>
<!-- MainPage.xaml -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ShoppingListApp.MainPage">

    <VerticalStackLayout Padding="20" Spacing="12">

        <Entry x:Name="TitleEntry"
               Placeholder="Название покупки" />

        <Entry x:Name="QuantityEntry"
               Placeholder="Количество"
               Keyboard="Numeric" />

        <Picker x:Name="CategoryPicker"
                Title="Категория">
            <Picker.Items>
                <x:String>Продукты</x:String>
                <x:String>Быт</x:String>
                <x:String>Одежда</x:String>
            </Picker.Items>
        </Picker>

        <HorizontalStackLayout Spacing="10">
            <CheckBox x:Name="PurchasedCheckBox" />
            <Label Text="Куплено"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>

        <HorizontalStackLayout Spacing="10">
            <Button Text="Добавить"
                    Clicked="OnAddClicked" />
            <Button Text="Сохранить"
                    Clicked="OnSaveClicked" />
        </HorizontalStackLayout>

        <CollectionView ItemsSource="{Binding Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" Margin="0,5">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding Title}"
                                   FontAttributes="Bold"
                                   FontSize="16">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsPurchased}"
                                                 Value="True">
                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Label Text="{Binding Quantity, StringFormat='Количество: {0}'}" />
                            <Label Text="{Binding Category, StringFormat='Категория: {0}'}" />
                            <HorizontalStackLayout Spacing="10">
                                <CheckBox IsChecked="{Binding IsPurchased}"
                                          CheckedChanged="OnPurchasedCheckedChanged" />
                                <Label Text="Куплено"
                                       VerticalOptions="Center" />
                                <Button Text="Удалить"
                                        Clicked="OnDeleteClicked" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>